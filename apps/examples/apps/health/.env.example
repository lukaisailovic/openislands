# Whoop connector (connectors/whoop) — OAuth2 credentials from a Whoop developer app.
# Create one at https://developer.whoop.com, set the redirect URI to your dashboard's
# /api/connectors/whoop/auth/callback, then copy this file to .env and fill these in.
# .env is gitignored; secrets never leave your machine.
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
