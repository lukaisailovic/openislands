{
  "version": 1,
  "title": "Operations Review",
  "icon": "pulse",
  "datasets": {
    "summary": { "source": "data/summary.csv", "description": "weekly ops KPI rollup (open issues, p95 latency, uptime, error budget, deploys)" },
    "throughput": { "source": "data/throughput.csv", "description": "weekly shipped vs committed" },
    "burndown": { "source": "data/burndown.csv", "description": "current sprint: remaining vs ideal by day" },
    "services": { "source": "data/services.csv", "description": "service health snapshot" },
    "services_health": { "sql": "models/transforms/services_health.sql", "description": "services with a derived status signal, problems first" },
    "incidents": { "source": "data/incidents.csv", "description": "recent incidents (written via log_incident)" }
  },
  "actions": {
    "log_incident": {
      "dataset": "incidents",
      "mode": "insert",
      "description": "Record an incident on the timeline",
      "fields": {
        "severity": { "enum": ["Sev-1", "Sev-2", "Sev-3"] },
        "status": { "enum": ["investigating", "monitoring", "resolved"] }
      }
    }
  },
  "pages": [
    {
      "id": "overview",
      "title": "Overview",
      "icon": "chart-line",
      "filters": [
        { "id": "period", "type": "daterange", "label": "Period", "bind": { "burndown": "day" } }
      ],
      "islands": [
        { "type": "layout.row", "id": "kpis", "islands": [
          { "type": "metric.kpi", "title": "Shipped this week", "dataset": "throughput", "value": "shipped", "compareTo": "prev", "format": "int", "span": 3 },
          { "type": "metric.kpi", "title": "Open issues", "dataset": "summary", "value": "open_issues", "compareTo": "prev", "format": "int", "span": 3 },
          { "type": "metric.kpi", "title": "p95 latency", "dataset": "summary", "value": "p95_latency_ms", "compareTo": "prev", "format": "int", "unit": "ms", "span": 3 },
          { "type": "metric.kpi", "title": "Uptime", "dataset": "summary", "value": "uptime_pct", "compareTo": "prev", "format": "pct", "span": 3 }
        ] },
        { "type": "layout.row", "id": "delivery", "islands": [
          { "type": "timeseries.line", "title": "Throughput vs commitment", "dataset": "throughput", "x": "week", "y": "shipped", "options": { "goalField": "committed" }, "span": 7 },
          { "type": "gauge.goal", "title": "Error budget remaining", "dataset": "summary", "goals": [{ "value": "error_budget_pct", "goal": { "min": 0.2 }, "format": "pct", "label": "remaining" }], "span": 5 }
        ] },
        { "type": "timeseries.line", "title": "Sprint burndown", "dataset": "burndown", "x": "day", "y": "remaining", "options": { "goalField": "ideal" }, "span": 12 }
      ]
    },
    {
      "id": "services",
      "title": "Services",
      "icon": "pulse",
      "filters": [
        { "id": "team", "type": "select", "label": "Team", "multiple": true, "bind": { "services": "owner", "services_health": "owner" } }
      ],
      "groups": [
        {
          "id": "health",
          "title": "Health",
          "islands": [
            { "type": "status.grid", "title": "Service status", "dataset": "services", "label": "service", "state": "status", "value": "p95_ms", "format": "int", "span": 12 },
            { "type": "table.grid", "title": "Service health", "dataset": "services_health", "span": 12, "columns": [
              { "field": "service", "label": "Service" },
              { "field": "status", "label": "Status", "status": { "signal": "status_signal" } },
              { "field": "p95_ms", "label": "p95 (ms)", "format": "int" },
              { "field": "error_rate", "label": "Error rate", "format": "pct" },
              { "field": "uptime_pct", "label": "Uptime", "format": "pct" },
              { "field": "owner", "label": "Owner" }
            ] },
            { "type": "category.bar", "title": "p95 by service", "dataset": "services", "x": "service", "y": "p95_ms", "span": 12 },

            { "type": "rank.list", "title": "Slowest services by p95", "dataset": "services", "label": "service", "value": "p95_ms", "secondary": "owner", "sort": "descending", "limit": 6, "format": "int", "span": 12 }
          ]
        },
        {
          "id": "incidents",
          "title": "Incidents",
          "islands": [
            { "type": "form.entry", "title": "Report an incident", "action": "log_incident", "submitLabel": "Report", "span": 5 },
            { "type": "timeline.feed", "title": "Recent incidents", "dataset": "incidents", "ts": "ts", "titleField": "title", "span": 7,
              "footer": [ { "field": "severity", "pill": true }, { "field": "status" } ],
              "details": [ { "field": "service", "label": "Service" }, { "field": "summary", "label": "Summary" } ] }
          ]
        },
        {
          "id": "docs",
          "title": "Docs",
          "islands": [
            { "type": "source.doc", "title": "Runbook", "kind": "markdown", "file": "docs/runbook.md", "span": 6 },
            { "type": "note.card", "title": "On-call", "span": 6, "markdown": "## On-call\n\n- **Primary** carries the pager; ack within 5 min.\n- Sev-1 → start a bridge, post in #incidents, page the service owner.\n- After any Sev-1/2, file a postmortem within 48h.\n- Keep the runbook current — future-you is on call too." }
          ]
        }
      ]
    }
  ]
}
