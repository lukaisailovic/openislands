{
  "name": "@openislands/storage",
  "version": "0.3.0",
  "description": "OpenIslands storage ports — swappable ContentStore / AppStateStore / VersionStore so the runtime can be backed by local disk or another backend.",
  "keywords": ["openislands", "storage", "content-store", "filesystem", "adapter", "port", "local-first", "pluggable", "backend", "esm"],
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/lukaisailovic/openislands",
  "repository": {
    "type": "git",
    "url": "https://github.com/lukaisailovic/openislands.git",
    "directory": "packages/storage"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "vitest": "^3.2.4"
  }
}
