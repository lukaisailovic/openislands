{
  "name": "@openislands/compiler",
  "version": "0.1.0",
  "description": "OpenIslands compiler — turns local files into typed data contracts and build-time snapshots.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/lukaisailovic/openislands",
  "repository": {
    "type": "git",
    "url": "https://github.com/lukaisailovic/openislands.git",
    "directory": "packages/compiler"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@duckdb/node-api": "1.5.3-r.3",
    "@openislands/connector-kit": "workspace:*",
    "@openislands/schema": "workspace:*",
    "@openislands/storage": "workspace:*",
    "apache-arrow": "^21.1.0",
    "esbuild": "^0.28.0",
    "ms": "^2.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/ms": "^2.1.0",
    "@types/node": "^22.10.0",
    "vitest": "^3.2.4"
  }
}
