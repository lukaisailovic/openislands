{
  "name": "@openislands/schema",
  "version": "0.2.0",
  "description": "OpenIslands manifest, island, and data-contract schemas — the single source of truth.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/lukaisailovic/openislands",
  "repository": {
    "type": "git",
    "url": "https://github.com/lukaisailovic/openislands.git",
    "directory": "packages/schema"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
