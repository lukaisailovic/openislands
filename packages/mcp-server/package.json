{
  "name": "@openislands/mcp",
  "version": "0.3.1",
  "description": "OpenIslands MCP server — read-many / write-one, so an agent edits your dashboard safely.",
  "keywords": [
    "openislands",
    "mcp",
    "model-context-protocol",
    "ai-agent",
    "llm-tools",
    "dashboard",
    "duckdb",
    "data-app",
    "local-first",
    "claude"
  ],
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/lukaisailovic/openislands",
  "repository": {
    "type": "git",
    "url": "https://github.com/lukaisailovic/openislands.git",
    "directory": "packages/mcp-server"
  },
  "bin": {
    "openislands-mcp": "./dist/index.mjs"
  },
  "exports": {
    "./http": {
      "types": "./src/http.ts",
      "default": "./src/http.ts"
    }
  },
  "publishConfig": {
    "bin": {
      "openislands-mcp": "./dist/index.mjs"
    },
    "exports": {
      "./http": {
        "types": "./dist/http.d.mts",
        "default": "./dist/http.mjs"
      }
    }
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "tsdown src/index.ts src/http.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openislands/compiler": "workspace:*",
    "@openislands/schema": "workspace:*",
    "@openislands/storage": "workspace:*",
    "diff": "^9.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "vitest": "^3.2.4"
  }
}
