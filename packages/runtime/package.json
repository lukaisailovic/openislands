{
  "name": "@openislands/runtime",
  "version": "0.4.4",
  "description": "OpenIslands runtime — the TanStack Start SSR app and island registry.",
  "keywords": [
    "openislands",
    "dashboard",
    "tanstack-start",
    "ssr",
    "react",
    "island",
    "duckdb",
    "data-app",
    "local-first",
    "echarts"
  ],
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/lukaisailovic/openislands",
  "repository": {
    "type": "git",
    "url": "https://github.com/lukaisailovic/openislands.git",
    "directory": "packages/runtime"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./islands": {
      "types": "./src/islands/index.ts",
      "default": "./src/islands/index.ts"
    },
    "./server": {
      "types": "./src/server-entry.d.ts",
      "default": "./dist/server/server.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "./islands": {
        "types": "./dist/islands/index.d.mts",
        "default": "./dist/islands/index.mjs"
      },
      "./server": {
        "default": "./dist/server/server.js"
      }
    }
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "vite build && tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@cloudflare/kumo": "^2.5.1",
    "@duckdb/node-api": "1.5.3-r.3",
    "@lexical/code": "^0.45.0",
    "@lexical/link": "^0.45.0",
    "@lexical/list": "^0.45.0",
    "@lexical/markdown": "^0.45.0",
    "@lexical/react": "^0.45.0",
    "@lexical/rich-text": "^0.45.0",
    "@lexical/selection": "^0.45.0",
    "@lexical/table": "^0.45.0",
    "@lexical/utils": "^0.45.0",
    "@openislands/compiler": "workspace:*",
    "@openislands/schema": "workspace:*",
    "@openislands/storage": "workspace:*",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-start": "^1.168.25",
    "chokidar": "^5.0.0",
    "echarts": "^6.1.0",
    "esbuild": "^0.28.0",
    "lexical": "^0.45.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "happy-dom": "^20.10.2",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.2.4"
  }
}
