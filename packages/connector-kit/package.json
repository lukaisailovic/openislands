{
  "name": "@openislands/connector-kit",
  "version": "0.5.2",
  "description": "OpenIslands connector authoring kit — the typed contract a vendored connector implements.",
  "keywords": [
    "openislands",
    "connector",
    "data-sync",
    "oauth2",
    "etl",
    "zod",
    "integration",
    "typescript",
    "bearer-token",
    "local-first"
  ],
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/lukaisailovic/openislands",
  "repository": {
    "type": "git",
    "url": "https://github.com/lukaisailovic/openislands.git",
    "directory": "packages/connector-kit"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
